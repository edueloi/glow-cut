// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// To switch to MySQL:
// 1. Change provider to "mysql"
// 2. Update DATABASE_URL in .env
// 3. Run prisma migrate dev

model Professional {
  id           String        @id @default(uuid())
  name         String
  role         String?       // e.g. "Barbeiro", "Manicure"
  password     String?       // for professional login
  appointments Appointment[]
  workingHours WorkingHours[]
}

model Client {
  id           String        @id @default(uuid())
  name         String
  phone        String        @unique
  age          Int?
  appointments Appointment[]
  comandas     Comanda[]
  createdAt    DateTime      @default(now())
}

model Service {
  id          String           @id @default(uuid())
  name        String
  description String?
  price       Float
  duration    Int              // in minutes
  type        String           // 'service' or 'package'
  discount    Float?           @default(0)
  discountType String?         @default("value")
  
  appointments Appointment[]
  packageServices PackageService[] @relation("PackageToService")
  includedInPackages PackageService[] @relation("ServiceInPackage")
}

model PackageService {
  id        String  @id @default(uuid())
  packageId String
  package   Service @relation("PackageToService", fields: [packageId], references: [id])
  serviceId String
  service   Service @relation("ServiceInPackage", fields: [serviceId], references: [id])
  quantity  Int     @default(1)
}

model Appointment {
  id             String       @id @default(uuid())
  date           DateTime
  startTime      String
  endTime        String
  status         String       @default("scheduled") // scheduled, confirmed, cancelled
  type           String       @default("atendimento") // atendimento, bloqueio, pessoal

  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id])

  serviceId      String?
  service        Service?     @relation(fields: [serviceId], references: [id])

  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])

  comandaId      String?
  comanda        Comanda?     @relation(fields: [comandaId], references: [id])

  sessionNumber  Int?         @default(1)
  totalSessions  Int?         @default(1)

  createdAt      DateTime     @default(now())
}

model Comanda {
  id           String        @id @default(uuid())
  status       String        @default("open") // open, paid
  total        Float         @default(0)
  discount     Float         @default(0)
  discountType String        @default("value")
  
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id])
  
  appointments Appointment[]
  createdAt    DateTime      @default(now())
}

model WorkingHours {
  id             String        @id @default(uuid())
  dayOfWeek      Int
  isOpen         Boolean       @default(true)
  startTime      String        @default("09:00")
  endTime        String        @default("18:00")
  breakStart     String        @default("12:00")
  breakEnd       String        @default("13:00")
  
  professionalId String?
  professional   Professional? @relation(fields: [professionalId], references: [id])
}

model ClosedDay {
  id          String   @id @default(uuid())
  date        DateTime @unique
  description String?
}

// ─── Super Admin (único, hardcoded, dono do SaaS) ───────────────────────────
model SuperAdmin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

// ─── Planos de assinatura ────────────────────────────────────────────────────
model Plan {
  id                  String   @id @default(uuid())
  name                String   // "Básico", "Pro", "Enterprise"
  price               Float    @default(0)
  maxProfessionals    Int      @default(3)
  maxAdminUsers       Int      @default(1)
  canCreateAdminUsers Boolean  @default(false)
  canDeleteAccount    Boolean  @default(false)
  features            String   @default("[]") // JSON array of feature strings
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  tenants             Tenant[]
}

// ─── Parceiros / Tenants ─────────────────────────────────────────────────────
model Tenant {
  id           String      @id @default(uuid())
  name         String      // Nome do salão/barbearia
  slug         String      @unique // URL slug
  ownerName    String
  ownerEmail   String
  ownerPhone   String?
  planId       String
  plan         Plan        @relation(fields: [planId], references: [id])
  isActive     Boolean     @default(true)
  notes        String?
  createdAt    DateTime    @default(now())
  adminUsers   AdminUser[]
}

// ─── Usuários Admin (criados pelo super admin ou pelo próprio tenant) ─────────
model AdminUser {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  password       String
  role           String   @default("admin") // "admin" | "manager" | "viewer"
  jobTitle       String?  // "Gerente", "Recepcionista"
  bio            String?
  phone          String?
  canCreateUsers Boolean  @default(false)
  canDeleteAccount Boolean @default(false)
  isActive       Boolean  @default(true)
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  createdAt      DateTime @default(now())
  lastLogin      DateTime?
}

// ─── Legacy user model (mantido por compatibilidade) ─────────────────────────
model User {
  id       String @id @default(uuid())
  username String @unique
  password String
  role     String @default("admin")
}
