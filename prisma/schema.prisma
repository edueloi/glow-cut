generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id               String    @id @db.VarChar(36)
  name             String    @db.VarChar(255)
  email            String    @unique(map: "AdminUser_email_key") @db.VarChar(255)
  password         String    @db.VarChar(255)
  role             String    @default("admin") @db.VarChar(20)
  jobTitle         String?   @db.VarChar(100)
  bio              String?   @db.VarChar(1000)
  phone            String?   @db.VarChar(30)
  photo            String?   @db.Text
  canCreateUsers   Boolean   @default(false)
  canDeleteAccount Boolean   @default(false)
  isActive         Boolean   @default(true)
  tenantId         String    @db.VarChar(36)
  permissions      String?   @db.Text
  createdAt        DateTime  @default(now()) @db.DateTime(0)
  lastLogin        DateTime? @db.DateTime(0)
  tenant           Tenant    @relation(fields: [tenantId], references: [id], map: "fk_admin_tenant")

  @@index([tenantId], map: "fk_admin_tenant")
}

model Appointment {
  id             String       @id @db.VarChar(36)
  date           DateTime     @db.DateTime(0)
  startTime      String       @db.VarChar(5)
  endTime        String       @db.VarChar(5)
  status         String       @default("scheduled") @db.VarChar(20)
  type           String       @default("atendimento") @db.VarChar(20)
  clientId       String?      @db.VarChar(36)
  serviceId      String?      @db.VarChar(36)
  professionalId String       @db.VarChar(36)
  comandaId      String?      @db.VarChar(36)
  sessionNumber  Int?         @default(1)
  totalSessions  Int?         @default(1)
  repeatGroupId  String?      @db.VarChar(36)
  duration       Int?         @default(60)
  notes          String?      @db.VarChar(2000)
  tenantId       String?      @db.VarChar(36)
  createdAt      DateTime     @default(now()) @db.DateTime(0)
  client         Client?      @relation(fields: [clientId], references: [id], map: "fk_appt_client")
  comanda        Comanda?     @relation(fields: [comandaId], references: [id], map: "fk_appt_comanda")
  professional   Professional @relation(fields: [professionalId], references: [id], map: "fk_appt_professional")
  service        Service?     @relation(fields: [serviceId], references: [id], map: "fk_appt_service")

  @@index([clientId], map: "fk_appt_client")
  @@index([comandaId], map: "fk_appt_comanda")
  @@index([professionalId], map: "fk_appt_professional")
  @@index([serviceId], map: "fk_appt_service")
}

model Client {
  id          String        @id @db.VarChar(36)
  name        String        @db.VarChar(255)
  phone       String        @db.VarChar(30)
  age         Int?
  createdAt   DateTime      @default(now()) @db.DateTime(0)
  tenantId    String?       @db.VarChar(36)
  appointment Appointment[]
  comanda     Comanda[]

  @@unique([phone, tenantId], map: "Client_phone_tenantId_key")
  @@index([tenantId], map: "Client_tenantId_idx")
  @@index([tenantId], map: "idx_client_tenant")
}

model ClosedDay {
  id          String   @id @db.VarChar(36)
  date        DateTime @db.DateTime(0)
  description String?  @db.VarChar(255)
  tenantId    String?  @db.VarChar(36)

  @@unique([date, tenantId], map: "ClosedDay_date_tenantId_key")
  @@index([tenantId], map: "ClosedDay_tenantId_idx")
  @@index([tenantId], map: "idx_closedday_tenant")
}

model Comanda {
  id             String        @id @db.VarChar(36)
  status         String        @default("open") @db.VarChar(20)
  total          Float         @default(0)
  discount       Float         @default(0)
  discountType   String        @default("value") @db.VarChar(20)
  clientId       String?       @db.VarChar(36)
  tenantId       String?       @db.VarChar(36)
  professionalId String?       @db.VarChar(36)
  description    String?       @db.VarChar(1000)
  paymentMethod  String?       @db.VarChar(30)
  sessionCount   Int?          @default(1)
  type           String?       @default("normal") @db.VarChar(20)
  createdAt      DateTime      @default(now()) @db.DateTime(0)
  appointment    Appointment[]
  items          ComandaItem[]
  client         Client?       @relation(fields: [clientId], references: [id], map: "fk_comanda_client")

  @@index([clientId], map: "fk_comanda_client")
  @@index([professionalId], map: "idx_comanda_prof")
  @@index([professionalId], map: "idx_comanda_professional")
  @@index([tenantId], map: "idx_comanda_tenant")
}

model PackageService {
  id                                        String  @id @db.VarChar(36)
  packageId                                 String  @db.VarChar(36)
  serviceId                                 String  @db.VarChar(36)
  quantity                                  Int     @default(1)
  service_packageservice_packageIdToservice Service @relation("packageservice_packageIdToservice", fields: [packageId], references: [id], onDelete: Cascade, map: "fk_pkg_package")
  service_packageservice_serviceIdToservice Service @relation("packageservice_serviceIdToservice", fields: [serviceId], references: [id], onDelete: Cascade, map: "fk_pkg_service")

  @@index([packageId], map: "fk_pkg_package")
  @@index([serviceId], map: "fk_pkg_service")
}

model Product {
  id              String           @id @db.VarChar(36)
  name            String           @db.VarChar(255)
  description     String?          @db.Text
  photo           String?          @db.Text
  costPrice       Float            @default(0)
  salePrice       Float            @default(0)
  stock           Int              @default(0)
  reservedStock   Int              @default(0)
  minStock        Int              @default(0)
  unit            String           @default("un") @db.VarChar(20)
  validUntil      DateTime?        @db.DateTime(0)
  code            String?          @db.VarChar(100)
  isForSale       Boolean          @default(true)
  tenantId        String?          @db.VarChar(36)
  sectorId        String?          @db.VarChar(36)
  metadata        String?          @db.Text
  createdAt       DateTime         @default(now()) @db.DateTime(0)
  comandaItem     ComandaItem[]
  serviceProducts ServiceProduct[]

  @@index([tenantId], map: "idx_product_tenant")
}

model ComandaItem {
  id          String   @id @db.VarChar(36)
  comandaId   String   @db.VarChar(36)
  productId   String?  @db.VarChar(36)
  serviceId   String?  @db.VarChar(36)
  name        String   @db.VarChar(255)
  price       Float    @default(0)
  quantity    Int      @default(1)
  total       Float    @default(0)
  createdAt   DateTime @default(now()) @db.DateTime(0)

  comanda     Comanda  @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
  service     Service? @relation(fields: [serviceId], references: [id])

  @@index([comandaId], map: "idx_comandaitem_comanda")
  @@index([productId], map: "idx_comandaitem_product")
  @@index([serviceId], map: "idx_comandaitem_service")
}


model Plan {
  id                  String   @id @db.VarChar(36)
  name                String   @db.VarChar(100)
  price               Float    @default(0)
  maxProfessionals    Int      @default(3)
  maxAdminUsers       Int      @default(1)
  canCreateAdminUsers Boolean  @default(false)
  canDeleteAccount    Boolean  @default(false)
  features            String?  @default("[]") @db.VarChar(2000)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now()) @db.DateTime(0)
  tenant              Tenant[]
}

model Professional {
  id           String         @id @db.VarChar(36)
  name         String         @db.VarChar(255)
  role         String?        @db.VarChar(100)
  password     String?        @db.VarChar(255)
  phone        String?        @db.VarChar(30)
  email        String?        @db.VarChar(255)
  bio          String?        @db.VarChar(1000)
  photo        String?        @db.Text
  permissions  String?        @default("{}") @db.VarChar(2000)
  isActive     Boolean        @default(true)
  tenantId     String?        @db.VarChar(36)
  appointment  Appointment[]
  workinghours WorkingHours[]

  @@index([tenantId], map: "Professional_tenantId_idx")
  @@index([tenantId], map: "idx_professional_tenant")
}

model Service {
  id                                               String           @id @db.VarChar(36)
  name                                             String           @db.VarChar(255)
  description                                      String?          @db.Text
  price                                            Float
  duration                                         Int
  type                                             String           @default("service") @db.VarChar(20)
  discount                                         Float            @default(0)
  discountType                                     String           @default("value") @db.VarChar(20)
  tenantId                                         String?          @db.VarChar(36)
  photo                                            String?          @db.Text
  professionalIds                                  String?          @default("[]") @db.VarChar(2000)
  createdAt                                        DateTime         @default(now()) @db.DateTime(0)
  appointment                                      Appointment[]
  comandaItem                                      ComandaItem[]
  serviceProducts                                  ServiceProduct[]
  packageservice_packageservice_packageIdToservice PackageService[] @relation("packageservice_packageIdToservice")
  packageservice_packageservice_serviceIdToservice PackageService[] @relation("packageservice_serviceIdToservice")

  @@index([tenantId], map: "idx_service_tenant")
}

model ServiceProduct {
  id        String  @id @db.VarChar(36)
  serviceId String  @db.VarChar(36)
  productId String  @db.VarChar(36)
  quantity  Float   @default(1)

  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([serviceId], map: "idx_svcprod_service")
  @@index([productId], map: "idx_svcprod_product")
}

model WorkingHours {
  id             String       @id @db.VarChar(36)
  dayOfWeek      Int
  isOpen         Boolean      @default(true)
  startTime      String       @default("09:00") @db.VarChar(5)
  endTime        String       @default("19:00") @db.VarChar(5)
  breakStart     String       @default("12:00") @db.VarChar(5)
  breakEnd       String       @default("13:00") @db.VarChar(5)
  professionalId String?      @db.VarChar(36)
  professional   Professional? @relation(fields: [professionalId], references: [id], map: "fk_wh_professional")

  @@index([professionalId], map: "fk_wh_professional")
}

model Tenant {
  id                    String      @id @db.VarChar(36)
  name                  String      @db.VarChar(255)
  slug                  String      @unique @db.VarChar(100)
  ownerName             String      @db.VarChar(255)
  ownerEmail            String      @db.VarChar(255)
  ownerPhone            String?     @db.VarChar(30)
  planId                String      @db.VarChar(36)
  isActive              Boolean     @default(true)
  notes                 String?     @db.Text
  createdAt             DateTime    @default(now()) @db.DateTime(0)
  expiresAt             DateTime?   @db.DateTime(0)
  blockedAt             DateTime?   @db.DateTime(0)
  maxAdminUsersOverride Int?
  themeColor            String?     @db.VarChar(20)
  logoUrl               String?     @db.Text
  coverUrl              String?     @db.Text
  address               String?     @db.Text
  instagram             String?     @db.VarChar(100)
  welcomeMessage        String?     @db.Text
  description           String?     @db.Text
  adminuser             AdminUser[]
  plan                  Plan        @relation(fields: [planId], references: [id], map: "fk_tenant_plan")

  @@index([planId], map: "fk_tenant_plan")
}

model SuperAdmin {
  id        String   @id @db.VarChar(36)
  username  String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  createdAt DateTime @default(now()) @db.DateTime(0)
}

model WppBotConfig {
  id               String   @id @default(uuid()) @db.VarChar(36)
  tenantId         String   @unique @db.VarChar(36)
  botEnabled       Boolean  @default(false)
  sendConfirmation Boolean  @default(true)
  sendReminder24h  Boolean  @default(true)
  sendBirthday     Boolean  @default(true)
  sendCobranca     Boolean  @default(false)
  sendWelcome      Boolean  @default(true)
  menuEnabled      Boolean  @default(false)
  menuWelcomeMsg   String?  @db.Text
  menuOptions      String?  @db.Text
  createdAt        DateTime @default(now()) @db.DateTime(0)
  updatedAt        DateTime @updatedAt @db.DateTime(0)
}

model WppMessageTemplate {
  id        String   @id @default(uuid()) @db.VarChar(36)
  tenantId  String   @db.VarChar(36)
  type      String   @db.VarChar(50)
  name      String   @db.VarChar(255)
  body      String   @db.Text
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now()) @db.DateTime(0)
  updatedAt DateTime @updatedAt @db.DateTime(0)

  @@unique([tenantId, type])
}